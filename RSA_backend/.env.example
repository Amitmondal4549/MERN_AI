# ─── Server ───────────────────────────────────────────
PORT=4000
NODE_ENV=development

# Comma-separated list of allowed CORS origins (optional)
# CORS_ORIGIN=http://localhost:5173,https://your-app.railway.app

# ─── MongoDB ──────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority

# ─── Cohere AI ────────────────────────────────────────
COHERE_API_KEY=your_cohere_api_key_here

# ─── Firebase Admin (for token verification) ──────────
# These are optional — auth will be disabled if not set
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── Admin Access ─────────────────────────────────────
# Comma-separated emails of admin users
# ADMIN_EMAILS=admin@example.com
